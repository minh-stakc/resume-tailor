%-----------EDUCATION-----------
\section{Education}
\resumeSubHeadingListStart
  \resumeSubheading
    {\VAR{education.institution}}{\VAR{education.location}}
    {\VAR{education.degree}}{\VAR{education.graduation}}
    \resumeItemListStart
      \resumeItem{GPA: \VAR{education.gpa}\BLOCK{if education.awards}; \VAR{education.awards}\BLOCK{endif}}
      \resumeItem{\VAR{education.coursework_label | default('Coursework')}: \VAR{education.coursework}}
    \resumeItemListEnd
\resumeSubHeadingListEnd

%-----------EXPERIENCE-----------
\section{Experience}
\resumeSubHeadingListStart

\BLOCK{for exp in experiences}
\resumeSubheading
  {\VAR{exp.company}}{\VAR{exp.location}}
  {\VAR{exp.title}}{\VAR{exp.start} -- \VAR{exp.end}}
    \resumeItemListStart
\BLOCK{for bullet in exp.bullets}
\resumeItem{\VAR{bullet | latex_escape}}
\BLOCK{endfor}
    \resumeItemListEnd

\BLOCK{endfor}
\resumeSubHeadingListEnd

%-----------PROJECTS-----------
\section{Projects}
\resumeSubHeadingListStart

\BLOCK{for project in projects}
\resumeProjectHeading
{\textbf{\VAR{project.name | latex_escape}} $|$ \emph{\VAR{project.tech_string | latex_escape}}}{\VAR{project.start} -- \VAR{project.end}}
\resumeItemListStart
\BLOCK{for bullet in project.bullets}
\resumeItem{\VAR{bullet | latex_escape}}
\BLOCK{endfor}
\resumeItemListEnd

\BLOCK{endfor}
\resumeSubHeadingListEnd

