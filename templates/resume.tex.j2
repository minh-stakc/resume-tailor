% Custom commands
\newcommand{\resumeItem}[1]{\item\normalsize{{#1 \vspace{0pt}}}}
\newcommand{\resumeSubheading}[4]{
  \vspace{0pt}\item
  \begin{tabular*}{0.97\textwidth}[t]{l@{\extracolsep{\fill}}r}
    \textbf{\normalsize #1} & \normalsize #2 \\
    \textit{\small#3} & \textit{\small #4} \\
  \end{tabular*}\vspace{0pt}
}
\newcommand{\resumeProjectHeading}[2]{
  \item
  \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
    \normalsize #1 & \normalsize #2 \\
  \end{tabular*}\vspace{0pt}
}
\newcommand{\resumeItemListStart}{\begin{itemize}[topsep=0pt, partopsep=0pt]}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{0pt}}
\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0.14in, label={}, topsep=0pt]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}

\renewcommand\labelitemi{$\bullet$}


